# Plato API Security Configuration
# Copy this file to .env and configure for your environment

# CORS Configuration
# Comma-separated list of allowed origins (no wildcards for security)
PLATO_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Production origin (if deployed)
# PLATO_PRODUCTION_ORIGIN=https://your-domain.com

# API Key Security
# Set to true to require API keys for all requests
PLATO_REQUIRE_API_KEY=false

# API Keys (format: KEY_ID:KEY_SECRET,KEY_ID2:KEY_SECRET2)
# Generate secure keys using: python -c "from plato.core.security import generate_api_key; print(generate_api_key())"
# PLATO_API_KEYS=plato_abc123:your-secret-key-here

# Rate Limiting
PLATO_RATE_LIMIT_ENABLED=true
PLATO_RATE_LIMIT_REQUESTS=100
PLATO_RATE_LIMIT_WINDOW=60

# Security Headers
PLATO_SECURITY_HEADERS=true
PLATO_CSP_ENABLED=true

# AI Provider API Keys (keep these secure!)
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GEMINI_API_KEY=your-gemini-key
# OPENROUTER_API_KEY=your-openrouter-key
# QWEN_BASE_URL=http://localhost:8000

# Server Configuration
PLATO_HOST=0.0.0.0
PLATO_PORT=8080
PLATO_LOG_LEVEL=info

# Development Mode (disables some security features for local development)
PLATO_DEV_MODE=false