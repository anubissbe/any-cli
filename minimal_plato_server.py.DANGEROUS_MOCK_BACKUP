#!/usr/bin/env python3
"""Minimal Plato server with essential endpoints."""

import asyncio
import time
import uvicorn
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field

# Create FastAPI app
app = FastAPI(
    title="Plato AI Orchestration System",
    description="AI orchestration system with MCP integration",
    version="0.1.0",
)

# Add CORS middleware
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Startup time for health checks
startup_time = time.time()

class HealthResponse(BaseModel):
    """Health check response."""
    status: str = Field(..., description="Health status")
    version: str = Field(..., description="Plato version")
    uptime: float = Field(..., description="Uptime in seconds")
    ai_providers: dict[str, bool] = Field(..., description="AI provider health")
    mcp_servers: dict[str, bool] = Field(..., description="MCP server health")

class ChatRequest(BaseModel):
    """Chat request from client."""
    message: str = Field(..., description="User message")
    session_id: str | None = Field(None, description="Session ID")

class ChatResponse(BaseModel):
    """Chat response to client."""
    message: str = Field(..., description="AI response")
    session_id: str = Field(..., description="Session ID")
    provider: str = Field(..., description="AI provider used")

@app.get("/health", response_model=HealthResponse)
async def health_check():
    """Health check endpoint."""
    return HealthResponse(
        status="healthy",
        version="0.1.0",
        uptime=time.time() - startup_time,
        ai_providers={"claude": False, "openai": False, "gemini": False},
        mcp_servers={"serena": False, "office-word": False, "archy": False},
    )

@app.post("/chat", response_model=ChatResponse)
async def chat(request: ChatRequest):
    """Send chat message to AI (mock response)."""
    return ChatResponse(
        message=f"Mock response to: {request.message}",
        session_id=request.session_id or "default-session",
        provider="mock",
    )

@app.get("/tools")
async def list_tools():
    """List available tools (mock)."""
    return {"tools": []}

@app.get("/sessions")
async def list_sessions():
    """List all sessions (mock)."""
    return {"sessions": []}

@app.get("/")
async def root():
    """Root endpoint."""
    return {"message": "Plato AI Orchestration System is running!"}

if __name__ == "__main__":
    uvicorn.run(app, host="0.0.0.0", port=8080, log_level="info")